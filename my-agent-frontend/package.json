{
  "name": "my-agent-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start:dev": "cross-env NODE_ENV=development vite --mode development",
    "start:staging": "cross-env NODE_ENV=staging vite --mode staging",
    "start:prod": "cross-env NODE_ENV=production vite --mode production",
    "build:dev": "cross-env NODE_ENV=development tsc -b && vite build --mode development",
    "build:staging": "cross-env NODE_ENV=staging tsc -b && vite build --mode staging",
    "build:prod": "cross-env NODE_ENV=production tsc -b && vite build --mode production",
    "build": "npm run build:prod",
    "preview": "vite preview --mode production",
    "preview:staging": "vite preview --mode staging",
    "dev": "npm run start:dev",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch"
  },
  "dependencies": {
    "@apollo/client": "^3.11.0",
    "@hookform/resolvers": "^3.9.0",
    "@sentry/react": "^8.0.0",
    "axios": "^1.7.0",
    "dayjs": "^1.11.0",
    "graphql": "^16.9.0",
    "graphql-request": "^7.1.0",
    "graphql-ws": "^5.16.0",
    "i18next": "^23.12.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^2.5.0",
    "radash": "^12.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "react-i18next": "^14.1.0",
    "react-router-dom": "^6.26.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typescript": "^4.0.0",
    "@graphql-codegen/typescript-operations": "^4.0.0",
    "@graphql-codegen/typescript-react-apollo": "^4.0.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "sass": "^1.99.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
